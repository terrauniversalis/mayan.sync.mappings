{
  "::::terra::sls::::": {
    "system": "::::fifa::2026::::",
    "type": "event_system",
    "status": "operational",
    "version": "1.1.0",
    "last_update": "2026-04-09",
    "scope": "conceptual_operational_blueprint",
    "core_entities": {
      "sede_id": "identificador transversal de sede",
      "evento_id": "identificador transversal de evento",
      "incidente_id": "identificador transversal de incidente",
      "responsable_id": "identificador transversal de responsable",
      "proveedor_id": "identificador transversal de proveedor",
      "contrato_id": "identificador transversal de contrato",
      "ticket_id": "identificador transversal de ticket"
    },
    "core_modules": {
      "infraestructura::command_center": {
        "description": "centro de control operativo en tiempo real",
        "components": [
          "dashboard_global",
          "live_alerts",
          "system_status",
          "data_streams",
          "incident_monitor"
        ],
        "tables": [
          "cc_events",
          "cc_alerts",
          "cc_logs",
          "cc_status"
        ],
        "fields": [
          "#Timestamp",
          "#Evento",
          "#Tipo",
          "#NivelCriticidad",
          "#Estado",
          "#Fuente",
          "#Responsable",
          "#SedeID",
          "#EventoID",
          "#IncidenteID"
        ]
      },
      "infraestructura::logistica": {
