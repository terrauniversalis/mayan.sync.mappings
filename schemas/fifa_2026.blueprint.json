        "tables": [
          "rutas",
          "vehiculos",
          "entregas",
          "centros_distribucion"
        ],
        "fields": [
          "#RutaID",
          "#Origen",
          "#Destino",
          "#Estado",
          "#TiempoEstimado",
          "#Proveedor",
          "#Fecha",
          "#ProveedorID",
          "#SedeID",
          "#EventoID"
        ]
      },
